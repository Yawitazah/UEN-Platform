generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("OPERATIONS")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ExchangeHub {
  id                     String                  @id @default(cuid())
  name                   String
  displayName            String
  hubType                String
  status                 String                  @default("ACTIVE")
  billingStatus          String                  @default("ACTIVE")
  logoUrl                String?
  brandColor             String?
  codePrefix             String?
  customDomain           String?
  subdomain              String?                 @unique
  uenValue               Decimal                 @default(1.00)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  holders                Holder[]
  universalExchangeNotes UniversalExchangeNote[]
  linkedMerchants        Merchant[]              @relation("LinkedExchangeHub")
  accessRules            MerchantAccessRule[]
  issuanceProducts       ShopifyIssuanceProduct[]
  inventoryCodes         UenCodeInventory[]
  digitalProducts        DigitalProduct[]
}

model Holder {
  id                     String                  @id @default(cuid())
  exchangeHubId          String
  firstName              String
  lastName               String
  email                  String
  phone                  String?
  status                 String                  @default("ACTIVE")
  portalToken            String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  exchangeHub            ExchangeHub             @relation(fields: [exchangeHubId], references: [id])
  universalExchangeNotes UniversalExchangeNote[]
  notifications          HolderNotification[]
  digitalProductLikes    DigitalProductLike[]
  digitalProductComments DigitalProductComment[]

  @@index([exchangeHubId])
  @@unique([exchangeHubId, email])
}

model UniversalExchangeNote {
  id             String               @id @default(cuid())
  code           String               @unique
  exchangeHubId  String
  holderId       String
  campaignId     String?
  status         String               @default("ACTIVE")
  issuedAt       DateTime             @default(now())
  expiresAt      DateTime?
  disabledAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  exchangeHub    ExchangeHub          @relation(fields: [exchangeHubId], references: [id])
  holder         Holder               @relation(fields: [holderId], references: [id])
  syncedNotes    ShopifySyncedNote[]
  inventoryCode  UenCodeInventory?

  @@index([exchangeHubId])
  @@index([holderId])
}

model Merchant {
  id                  String                @id @default(cuid())
  businessName        String
  platformType        String                @default("SHOPIFY")
  status              String                @default("ACTIVE")
  isExchangeHub       Boolean               @default(false)
  linkedExchangeHubId String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  linkedExchangeHub   ExchangeHub?          @relation("LinkedExchangeHub", fields: [linkedExchangeHubId], references: [id])
  offers              MerchantOffer[]
  accessRules         MerchantAccessRule[]
  shopifyConnections  ShopifyConnection[]
  syncedNotes         ShopifySyncedNote[]
  syncLogs            SyncLog[]
  apiKeys             MerchantApiKey[]
  inventorySyncs      ShopifyInventorySyncedCode[]
  discountGroups      ShopifyDiscountGroup[]
  onboardingRequests  MerchantOnboarding[]
}

model MerchantOffer {
  id                 String    @id @default(cuid())
  merchantId         String
  discountType       String
  discountValue      Decimal?
  minimumOrderAmount Decimal?
  usageLimitPerNote  Int       @default(1)
  startsAt           DateTime?
  endsAt             DateTime?
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  merchant           Merchant  @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

model MerchantAccessRule {
  id            String      @id @default(cuid())
  merchantId    String
  exchangeHubId String
  status        String      @default("ACTIVE")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  merchant      Merchant    @relation(fields: [merchantId], references: [id])
  exchangeHub   ExchangeHub @relation(fields: [exchangeHubId], references: [id])

  @@unique([merchantId, exchangeHubId])
  @@index([exchangeHubId])
}

model ShopifyConnection {
  id          String    @id @default(cuid())
  merchantId  String
  shopDomain  String
  accessToken String
  scopes      String
  status      String    @default("ACTIVE")
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  merchant    Merchant  @relation(fields: [merchantId], references: [id])

  @@unique([shopDomain])
  @@index([merchantId])
}

model ShopifySyncedNote {
  id                      String                @id @default(cuid())
  merchantId              String
  shopDomain              String
  universalExchangeNoteId String
  uenCode                 String
  shopifyDiscountId       String?
  shopifyDiscountCodeId   String?
  syncStatus              String                @default("PENDING")
  lastSyncedAt            DateTime?
  errorMessage            String?
  redeemedAt              DateTime?
  redeemedOrderId         String?
  redeemedOrderAmount     Decimal?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  merchant                Merchant              @relation(fields: [merchantId], references: [id])
  universalExchangeNote   UniversalExchangeNote @relation(fields: [universalExchangeNoteId], references: [id])

  @@unique([merchantId, universalExchangeNoteId])
  @@index([shopDomain])
  @@index([merchantId, redeemedAt])
}

model ShopifyIssuanceProduct {
  id               String           @id @default(cuid())
  exchangeHubId    String
  shopDomain       String
  shopifyProductId String
  productTitle     String?
  productImageUrl  String?
  digitalAssetUrl  String?
  digitalProductId String?
  status           String           @default("ACTIVE")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  exchangeHub      ExchangeHub      @relation(fields: [exchangeHubId], references: [id])
  digitalProduct   DigitalProduct?  @relation(fields: [digitalProductId], references: [id])
  issuanceLogs     UenIssuanceLog[]
  inventoryCodes   UenCodeInventory[]

  @@unique([shopDomain, shopifyProductId])
  @@index([exchangeHubId])
}

model UenCodeInventory {
  id                      String                  @id @default(cuid())
  exchangeHubId           String
  issuanceProductId        String?
  code                    String                  @unique
  status                  String                  @default("AVAILABLE")
  source                  String                  @default("GENERATED")
  issuedToEmail           String?
  universalExchangeNoteId String?                 @unique
  issuedAt                DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  exchangeHub             ExchangeHub             @relation(fields: [exchangeHubId], references: [id])
  issuanceProduct         ShopifyIssuanceProduct? @relation(fields: [issuanceProductId], references: [id])
  universalExchangeNote   UniversalExchangeNote?  @relation(fields: [universalExchangeNoteId], references: [id])
  shopifySyncs            ShopifyInventorySyncedCode[]

  @@index([exchangeHubId, status])
  @@index([issuanceProductId, status])
}

model ShopifyInventorySyncedCode {
  id                   String           @id @default(cuid())
  inventoryCodeId       String
  merchantId            String
  shopDomain            String
  uenCode               String
  shopifyDiscountId     String?
  shopifyDiscountCodeId String?
  syncStatus            String           @default("PENDING")
  lastSyncedAt          DateTime?
  errorMessage          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  inventoryCode         UenCodeInventory @relation(fields: [inventoryCodeId], references: [id])
  merchant              Merchant         @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, inventoryCodeId])
  @@index([shopDomain])
}

model ShopifyDiscountGroup {
  id                 String   @id @default(cuid())
  merchantId         String
  shopDomain         String
  discountKey        String
  title              String
  discountType       String
  discountValue      String?
  minimumOrderAmount String?
  usageLimitPerNote  Int
  shopifyDiscountId  String
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  merchant           Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, shopDomain, discountKey])
  @@index([shopDomain])
}

model UenIssuanceLog {
  id                     String                 @id @default(cuid())
  issuanceProductId       String
  shopDomain              String
  shopifyOrderId          String
  shopifyLineItemId       String
  customerEmail           String
  universalExchangeNoteId String?
  status                  String                 @default("ISSUED")
  message                 String?
  createdAt               DateTime               @default(now())
  issuanceProduct         ShopifyIssuanceProduct @relation(fields: [issuanceProductId], references: [id])

  @@unique([shopDomain, shopifyOrderId, shopifyLineItemId])
  @@index([customerEmail])
}

model SyncLog {
  id           String   @id @default(cuid())
  merchantId   String
  shopDomain   String?
  syncType     String
  status       String
  totalFetched Int      @default(0)
  totalCreated Int      @default(0)
  totalUpdated Int      @default(0)
  totalSkipped Int      @default(0)
  totalErrors  Int      @default(0)
  message      String?
  createdAt    DateTime @default(now())
  merchant     Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actorType  String   @default("system")
  entityType String
  entityId   String
  message    String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model MerchantApiKey {
  id         String    @id @default(cuid())
  merchantId String
  keyHash    String    @unique
  label      String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  merchant   Merchant  @relation(fields: [merchantId], references: [id])
}

model MerchantOnboarding {
  id                     String    @id @default(cuid())
  merchantId             String
  token                  String    @unique
  businessName           String
  contactName            String?
  contactEmail           String
  shopDomain             String
  requestedExchangeHubId String?
  status                 String    @default("REGISTERED")
  installedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  merchant               Merchant  @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([shopDomain])
}

model PortalBanner {
  id          String    @id @default(cuid())
  title       String
  body        String?
  imageUrl    String?
  linkUrl     String?
  linkLabel   String?
  bgColor     String    @default("#1f6f5b")
  textColor   String    @default("#ffffff")
  targetScope String    @default("ALL")
  status      String    @default("ACTIVE")
  priority    Int       @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model HolderNotification {
  id        String    @id @default(cuid())
  holderId  String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  holder    Holder    @relation(fields: [holderId], references: [id])

  @@index([holderId])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DigitalProduct {
  id               String                @id @default(cuid())
  exchangeHubId    String
  title            String
  artist           String?
  type             String                @default("ALBUM")
  artworkUrl       String?
  description      String?
  status           String                @default("ACTIVE")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  exchangeHub      ExchangeHub           @relation(fields: [exchangeHubId], references: [id])
  tracks           DigitalProductTrack[]
  issuanceProducts ShopifyIssuanceProduct[]

  @@index([exchangeHubId])
}

model DigitalProductTrack {
  id               String                  @id @default(cuid())
  digitalProductId String
  title            String
  trackNumber      Int
  fileUrl          String
  durationSeconds  Int?
  status           String                  @default("ACTIVE")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  digitalProduct   DigitalProduct          @relation(fields: [digitalProductId], references: [id])
  likes            DigitalProductLike[]
  comments         DigitalProductComment[]

  @@index([digitalProductId])
}

model DigitalProductLike {
  id        String              @id @default(cuid())
  holderId  String
  trackId   String
  createdAt DateTime            @default(now())
  holder    Holder              @relation(fields: [holderId], references: [id])
  track     DigitalProductTrack @relation(fields: [trackId], references: [id])

  @@unique([holderId, trackId])
  @@index([trackId])
}

model DigitalProductComment {
  id               String              @id @default(cuid())
  holderId         String
  trackId          String
  timestampSeconds Int                 @default(0)
  body             String
  createdAt        DateTime            @default(now())
  holder           Holder              @relation(fields: [holderId], references: [id])
  track            DigitalProductTrack @relation(fields: [trackId], references: [id])

  @@index([trackId, timestampSeconds])
}